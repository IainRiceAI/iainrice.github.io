---
import Layout from '../components/Layout.astro';
import PageHero from '../components/PageHero.astro';
---
<Layout title="Research | Professor Iain Rice">
  <PageHero eyebrow="Research profile" title="Applied AI research with clinical, industrial and social value." lede="My research background spans GenAI, machine learning, signal processing, cloud and software development across healthcare, defence, business and economic fields." />
  <section class="section"><div class="container grid-2">
    <div class="card"><h3>Healthcare AI</h3><p>Diabetes outcome prediction, medical image analysis for dementia characterisation, EEG analysis for intraoperative neurological monitoring and pre-eclampsia outcome prediction.</p></div>
    <div class="card"><h3>Immersive and simulation AI</h3><p>AI-enhanced VR/AR for medical simulation and training environments where learning, safety and assessment intersect.</p></div>
    <div class="card"><h3>Responsible GenAI</h3><p>LLM guardrails, cyber security implementation, GDPR-aware governance and organisational risk management.</p></div>
    <div class="card"><h3>Inclusive AI talent</h3><p>Work supporting the transition of female, black, disabled and low-income learners into AI fields through the ELAN project.</p></div>
  </div></section>
</Layout>
