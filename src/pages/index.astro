---
import Layout from '../components/Layout.astro';
---
<Layout title="Professor Iain Rice | Industrial AI, Governance & Research Leadership">
  <section class="hero">
    <div class="container hero-grid">
      <div>
        <span class="eyebrow">Professor of Industrial AI</span>
        <h1>Executive AI leadership for organisations that need impact, trust and scale.</h1>
        <p class="lede">I help businesses, public-sector partners and research teams turn AI ambition into governed, useful systems — spanning GenAI, predictive analytics, healthcare AI, FinTech, public safety and education.</p>
        <div class="hero-actions">
          <a class="btn" href="/industry/">Work with me</a>
          <a class="btn secondary" href="/research/">Explore research</a>
        </div>
        <div class="metrics">
          <div class="metric"><strong>100+</strong><span>academic staff led</span></div>
          <div class="metric"><strong>55</strong><span>consultancy projects and regulatory reports</span></div>
          <div class="metric"><strong>£3m+</strong><span>multi-stakeholder AI projects</span></div>
          <div class="metric"><strong>2000+</strong><span>MSc AI applications in 3 years</span></div>
        </div>
      </div>
      <aside class="portrait-card">
        <img src="/images/iain-picture.jpg" alt="Professor Iain Rice" />
        <div class="portrait-overlay">
          <h3>Professor Iain Rice, PhD</h3>
          <p>AI leader focused on strategic adoption, governance and applied research with measurable organisational outcomes.</p>
        </div>
      </aside>
    </div>
  </section>

  <section class="section dark">
    <div class="container grid-3">
      <div class="card">
        <h3>For business leaders</h3>
        <p>AI strategy, governance, LLM guardrails, predictive analytics and project assurance for regulated or high-stakes settings.</p>
      </div>
      <div class="card">
        <h3>For researchers</h3>
        <p>Collaborations in healthcare AI, medical imaging, EEG, VR/AR simulation, signal processing and responsible GenAI.</p>
      </div>
      <div class="card">
        <h3>For executive roles</h3>
        <p>Strategic and executive-level AI leadership, with particular interest in the UAE and international innovation ecosystems.</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container grid-2">
      <div class="banner">
        <div>
          <span class="eyebrow">Industrial AI in practice</span>
          <h2>Bridging research depth with board-level AI decisions.</h2>
          <div class="tags">
            <span class="tag">GenAI</span><span class="tag">Cloud</span><span class="tag">Governance</span><span class="tag">GDPR</span><span class="tag">Data Security</span>
          </div>
        </div>
      </div>
      <div class="card">
        <h2>Current focus</h2>
        <p>My work combines technical AI delivery with organisational adoption: identifying strategic gaps, building governed systems, developing teams and translating AI into regulated, useful outcomes.</p>
        <p>Recent and current areas include the RAPID project with Birmingham Children's Hospital, LLM integration and guardrails, GenAI cybersecurity, FinTech anomaly detection, public safety analytics and AI-enhanced healthcare research.</p>
        <a class="btn" href="/leadership/">See leadership profile</a>
      </div>
    </div>
  </section>
</Layout>
