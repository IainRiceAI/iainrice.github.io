---
import Layout from '../components/Layout.astro';
import PageHero from '../components/PageHero.astro';
---
<Layout title="Industry Collaboration | Professor Iain Rice">
  <PageHero eyebrow="Industry collaboration" title="AI consulting, governance and applied delivery for organisations." lede="I work with partners who need more than an AI demo: strategy, governance, data security, adoption, stakeholder confidence and measurable outcomes." />
  <section class="section">
    <div class="container grid-3">
      <div class="card"><h3>AI strategy</h3><p>Executive-level direction, opportunity discovery, gap analysis, AI roadmaps and delivery models aligned to corporate and regulatory requirements.</p></div>
      <div class="card"><h3>GenAI and LLMs</h3><p>LLM integration, guardrail deployment, GenAI cybersecurity, workflow design and risk-aware implementation.</p></div>
      <div class="card"><h3>Predictive analytics</h3><p>Forecasting, anomaly detection and custom dashboards for health, finance, public safety and operational decision-making.</p></div>
    </div>
  </section>
  <section class="section dark"><div class="container"><h2>Experience across high-stakes domains</h2><div class="tags"><span class="tag">Healthcare</span><span class="tag">Defence</span><span class="tag">FinTech</span><span class="tag">Public safety</span><span class="tag">Education</span><span class="tag">Economic development</span></div></div></section>
</Layout>
